-- 4. Professional Button Construction (Vignette Style Transparency)
local function createProButton(text, pos)
    local btn = Instance.new("TextButton", CanvasGroup)
    btn.Size = UDim2.new(0, 140, 0, 45)
    btn.Position = pos
    btn.AnchorPoint = Vector2.new(0, 1)
    btn.BackgroundColor3 = Color3.fromRGB(70, 170, 230)
    btn.BackgroundTransparency = 0
    btn.BorderSizePixel = 0
    btn.Text = text
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.ClipsDescendants = true
    
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    
    -- Solid Center -> Transparent Edges
    local grad = Instance.new("UIGradient", btn)
    grad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 1),
        NumberSequenceKeypoint.new(0.2, 0),
        NumberSequenceKeypoint.new(0.8, 0),
        NumberSequenceKeypoint.new(1, 1)
    })
    return btn
end

