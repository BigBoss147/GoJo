local function animateBtn(btn, normPos, hovPos)
    btn.MouseEnter:Connect(function()
        UserInputService.MouseIconEnabled = true
        TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Size = UDim2.new(0, 150, 0, 50), Position = hovPos}):Play()
    end)
    btn.MouseLeave:Connect(function()
        UserInputService.MouseIconEnabled = false
        TweenService:Create(btn, TweenInfo.new(0.2), {Size = UDim2.new(0, 140, 0, 45), Position = normPos}):Play()
    end)
    btn.MouseButton1Down:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.05), {Size = UDim2.new(0, 135, 0, 40)}):Play()
    end)
    btn.MouseButton1Up:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1, Enum.EasingStyle.Back), {Size = UDim2.new(0, 150, 0, 50)}):Play()
    end)
end

animateBtn(ExitBtn, UDim2.new(0, 20, 1, -40), UDim2.new(0, 20, 1, -38))
animateBtn(ChatBtn, UDim2.new(0, 170, 1, -40), UDim2.new(0, 170, 1, -38))

-- 6. Engine
local idx, dir, lastUpdate = 1, 1, 0
RunService.Heartbeat:Connect(function(dt)
    lastUpdate = lastUpdate + dt
    if lastUpdate >= frameDuration then
        imageInstances[idx].Visible = false
        idx = idx + dir
        if idx > #imageInstances or idx < 1 then dir = -dir idx = idx + dir * 2 end
        imageInstances[idx].Visible = true
        lastUpdate = lastUpdate - frameDuration
    end
end)

